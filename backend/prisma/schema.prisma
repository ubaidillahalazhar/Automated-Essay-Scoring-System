generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PendingUser {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  name           String
  password_hash  String
  role_id        Int
  otp_code       String
  otp_expires_at DateTime
  created_at     DateTime @default(now())
}

model User {
  user_id     Int             @id @default(autoincrement())
  name        String          @db.VarChar(255)
  role_id     Int
  created_at  DateTime        @default(now()) @db.Timestamp(6)
  updated_at  DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  quizzes     Quiz[]
  scoresGiven Score[]         @relation("ScoredBy")
  answers     StudentAnswer[]
  role        Role            @relation(fields: [role_id], references: [role_id])
  userDetail  UserDetail?
  subjects    Subject[]
}

model UserDetail {
  detail_id     Int       @id @default(autoincrement())
  user_id       Int       @unique
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)

  otp_code       String?  @db.VarChar(10)     
  otp_expires_at DateTime? @db.Timestamp(6)
  
  teaching_level String @default("SD")
  last_login    DateTime? @db.Timestamp(6)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @db.Timestamp(6)
  user          User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  grade_id      Int?
  grade         Grade?    @relation(fields: [grade_id], references: [grade_id])
}

model Role {
  role_id     Int      @id @default(autoincrement())
  role_name   String   @unique @db.VarChar(100)
  description String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)
  users       User[]
}
// ==========================================
// A. TABEL MASTER TINGKATAN KELAS (Global)
// ==========================================
model Grade {
  grade_id   Int          @id @default(autoincrement())
  grade_name String       @unique // Isinya: "Kelas 1", "Kelas 2", ..., "Kelas 6"
  school_level String
  quizzes    Quiz[]       // Relasi: Satu tingkatan kelas bisa memiliki banyak kuis
  users      UserDetail[] // Relasi: Hubungan ke tingkat kelas murid
}

// ==========================================
// B. TABEL MATA PELAJARAN (Terisolasi per Guru)
// ==========================================
model Subject {
  subject_id   Int      @id @default(autoincrement())
  subject_name String   // Contoh: "Matematika", "Bahasa Indonesia"
  teacher_id   Int      // Pemilik mata pelajaran ini
  teacher      User     @relation(fields: [teacher_id], references: [user_id])
  quizzes      Quiz[]   // Relasi: Satu mata pelajaran bisa dipakai di banyak kuis

  @@unique([subject_name, teacher_id]) // Kunci Keamanan: Guru tidak bisa membuat nama mapel ganda yang sama persis
}

model Quiz {
  quiz_id      Int             @id @default(autoincrement())
  title        String          @db.VarChar(255)
  description  String?         @db.Text
  time_limit   Int             @default(30)
  due_date     DateTime        @db.Timestamp(6)
  created_at   DateTime        @default(now()) @db.Timestamp(6)
  updated_at   DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  
  // 1. Relasi ke Guru (Pastikan HANYA ADA SATU INI)
  created_by   Int
  teacher      User            @relation(fields: [created_by], references: [user_id], onDelete: Cascade)

  // 2. Relasi ke Subject / Mapel (Kolom subject String yang lama DIHAPUS)
  subject_id   Int
  subject      Subject         @relation(fields: [subject_id], references: [subject_id])

  // 3. Relasi ke grade (Asumsi kamu menambahkan ini)
  grade_id     Int
  grade        Grade @relation(fields: [grade_id], references: [grade_id])

  // Relasi ke pertanyaan
  questions    EssayQuestion[]
}

model EssayQuestion {
  question_id   Int             @id @default(autoincrement())
  quiz_id       Int
  question_text String
  weight        Decimal         @default(1.00) @db.Decimal(5, 2)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @db.Timestamp(6)

  quiz          Quiz            @relation(fields: [quiz_id], references: [quiz_id], onDelete: Cascade)
  answerKey     AnswerKey?
  answers       StudentAnswer[]
}

model AnswerKey {
  key_id      Int           @id @default(autoincrement())
  question_id Int           @unique
  key_text    String
  created_at  DateTime      @default(now()) @db.Timestamp(6)
  updated_at  DateTime      @default(now()) @db.Timestamp(6)
  question    EssayQuestion @relation(fields: [question_id], references: [question_id], onDelete: Cascade)
}

model StudentAnswer {
  answer_id       Int           @id @default(autoincrement())
  question_id     Int
  user_id         Int
  answer_text     String
  word_count      Int           @default(0)
  submission_date DateTime      @default(now()) @db.Timestamp(6)
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  updated_at      DateTime      @default(now()) @db.Timestamp(6)
  score           Score?
  question        EssayQuestion @relation(fields: [question_id], references: [question_id])
  student         User          @relation(fields: [user_id], references: [user_id])
}

model Score {
  score_id    Int           @id @default(autoincrement())
  answer_id   Int           @unique
  ai_score    Decimal?      @db.Decimal(5, 2)
  final_score Decimal?      @db.Decimal(5, 2)
  feedback    String?       @db.Text
  scored_by   Int?
  scored_date DateTime      @default(now()) @db.Timestamp(6)
  created_at  DateTime      @default(now()) @db.Timestamp(6)
  updated_at  DateTime      @default(now()) @db.Timestamp(6)
  answer      StudentAnswer @relation(fields: [answer_id], references: [answer_id], onDelete: Cascade)
  teacher     User?          @relation("ScoredBy", fields: [scored_by], references: [user_id])
}
